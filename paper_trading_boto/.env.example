# Example configuration for Paper Trading BOTo
# Copy this file to `.env` and customise the values as needed.

# IBKR connection settings
TWS_HOST=127.0.0.1
# Paper trading port (7497) or live trading port (7496)
TWS_PORT=7497
# Unique client ID for API connection
CLIENT_ID=1
# IBKR account number (optional; use if you want to filter orders by account)
ACCOUNT=

# Database settings
# Path to a SQLite file for logging trades and account data.  Leave empty to disable.
DB_PATH=./trades.db

# Reporting settings
# Directory to store CSV and HTML reports
REPORT_DIR=reports

# Risk management defaults
MAX_PORTFOLIO_EXPOSURE=0.2   # max fraction of account value in open positions
STOP_LOSS_PCT=0.05           # 5 % stop‑loss
TAKE_PROFIT_PCT=0.1          # 10 % take‑profit
